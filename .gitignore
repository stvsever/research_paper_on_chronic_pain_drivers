# Study materials may carry identifiable questionnaire/project content; keep the codebook only.
src/utils/study_materials/*.pdf
src/utils/study_materials/*.docx
src/utils/study_materials/*.doc

# Model objects and per-person model input data may embed participant-level records.
src/results/models/**/*.rds
src/results/models/gimme_out/

# Do not publish row-level derived exports that can expose prompt-level participant traces.
src/results/tables/02_timing_long.csv
src/results/tables/04_imputation_example.csv
src/results/networks/05_mlvar_residuals_long.csv

# Do not publish participant-level derived exports with subject/pid rows or per-person estimates.
src/results/tables/02_compliance_per_person.csv
src/results/tables/04_stationarity_perperson.csv
src/results/tables/06_sgimme_inclusion.csv
src/results/tables/06_sgimme_subgroup_membership.csv
